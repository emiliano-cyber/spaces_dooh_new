# Credenciales del SDK de DOOHmain — copia a `.env` y rellena con valores reales.
# NO comitear el `.env` con valores. Todas son OBLIGATORIAS (sin defaults).

# API de DOOHmain
DOOHMAIN_API_KEY=
# Opcional; por defecto https://app.doohmain.com/api/v1/index.php
# DOOHMAIN_BASE_URL=

# BD PostgreSQL local del proyecto (tablas de tracking de la integración).
# Aplica el esquema una vez:  psql "<url>" -f doohmain_sdk/schema.sql
DB_HOST=localhost
DB_PORT=5433
DB_USER=spaces
DB_PASSWORD=spaces
DB_NAME=spaces
# true si la BD exige TLS (p. ej. Postgres gestionada en DO); local: false.
DB_SSL=false
