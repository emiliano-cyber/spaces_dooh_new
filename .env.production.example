# ════ BASE DE DATOS ════
DATABASE_URL=postgresql://spaces_user:PASSWORD@localhost:5432/spaces_prod

# ════ REDIS ════
REDIS_URL=redis://localhost:6379

# ════ AUTENTICACIÓN ════
JWT_SECRET=GENERA_CON_openssl_rand_-base64_64
COOKIE_DOMAIN=.{TENANT_SLUG}.spaces.com

# ════ DIGITALOCEAN SPACES ════
DO_SPACES_KEY=TU_SPACES_ACCESS_KEY
DO_SPACES_SECRET=TU_SPACES_SECRET_KEY
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=spaces-{TENANT_SLUG}
DO_SPACES_CDN_URL=https://spaces-{TENANT_SLUG}.nyc3.cdn.digitaloceanspaces.com

# ════ EMAIL ════
RESEND_API_KEY=re_TU_API_KEY
RESEND_FROM=no-reply@spaces.com

# ════ APP ════
NODE_ENV=production
PORT=3001
NEXT_PUBLIC_API_URL=https://{TENANT_SLUG}.spaces.com/api
LOG_LEVEL=info
